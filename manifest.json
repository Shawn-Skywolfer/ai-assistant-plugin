{
  "name": "AI Assistant",
  "id": "ai-assistant",
  "manifestVersion": 1,
  "version": "1.5.0",
  "minSupVersion": "13.0.0",
  "description": "OpenAI-powered AI assistant that can manage your tasks, projects, and tags via natural language.",
  "author": "Community",
  "hooks": ["taskComplete", "currentTaskChange"],
  "permissions": [
    "getTasks",
    "getArchivedTasks",
    "getCurrentContextTasks",
    "addTask",
    "updateTask",
    "deleteTask",
    "batchUpdateForProject",
    "getAllProjects",
    "addProject",
    "updateProject",
    "getAllTags",
    "addTag",
    "updateTag",
    "reorderTasks",
    "showSnack",
    "notify",
    "openDialog",
    "persistDataSynced",
    "loadSyncedData",
    "dispatchAction"
  ],
  "iFrame": true,
  "sidePanel": true,
  "isSkipMenuEntry": true,
  "icon": "icon.svg"
}
